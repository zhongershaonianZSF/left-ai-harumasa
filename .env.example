# 六课斥候请假小助手 · AI 后端环境变量配置
# 复制本文件为 .env 并填写真实值（.env 不要提交到 git/公开仓库）

# 必填：你的大模型 API Key（阿里云 DashScope / 任何 OpenAI 兼容服务）
AI_API_KEY=sk-你的key

# 可选：接口地址（默认阿里云 DashScope 兼容模式）
# AI_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# 可选：模型名（默认 qwen-plus）
# AI_MODEL=qwen-plus

# 可选：服务端口（默认 3000，云端平台一般会自动注入 PORT）
# PORT=3000
